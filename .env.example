# Shared
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# SQL Server
ACCEPT_EULA=Y
MSSQL_PID=Developer
MSSQL_PORT=1433
MSSQL_SA_PASSWORD=Change_this_password_123!
ConnectionStrings__SqlServer=Server=localhost,1433;Database=TransactionsManager;User Id=sa;Password=Change_this_password_123!;TrustServerCertificate=True

# RabbitMQ
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673
RabbitMq__Host=localhost
RabbitMq__Port=5673
RabbitMq__Username=guest
RabbitMq__Password=guest

# Auth
Jwt__Issuer=transactions-manager
Jwt__Audience=transactions-manager-client
Jwt__SigningKey=development-only-signing-key-change-before-production
Jwt__ExpirationMinutes=60
Auth__DevelopmentUser__Username=admin
Auth__DevelopmentUser__Password=Pass123!

# Client
VITE_API_BASE_URL=http://localhost:5080
VITE_SIGNALR_URL=http://localhost:5081/ws/transactions
