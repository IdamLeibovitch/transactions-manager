# Shared
ASPNETCORE_ENVIRONMENT=Development

# SQL Server
ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=Change_this_password_123!
ConnectionStrings__SqlServer=Server=mssql,1433;Database=TransactionsManager;User Id=sa;Password=Change_this_password_123!;TrustServerCertificate=True

# RabbitMQ
RabbitMq__Host=rabbitmq
RabbitMq__Username=guest
RabbitMq__Password=guest

# Auth
Jwt__Issuer=transactions-manager
Jwt__Audience=transactions-manager-client
Jwt__SigningKey=replace-with-local-development-signing-key

# Client
VITE_API_BASE_URL=http://localhost:5000
VITE_SIGNALR_URL=http://localhost:5001/ws/transactions

